// RENDER
// ════════════════════════════════════════════
function renderAll(){
  renderPageTabs();
  renderPagesList();
  renderCanvas();
}

function renderPageTabs(){
  const tabs=document.getElementById('pageTabs');
  tabs.innerHTML=pages.map((p,i)=>`
    <div class="tb-page-tab ${i===currentPageIdx?'active':''}" onclick="switchPage(${i})">${p.name}</div>
  `).join('');
}

function renderPagesList(){
  const list=document.getElementById('pagesList');
  list.innerHTML=pages.map((p,i)=>`
    <div class="page-item ${i===currentPageIdx?'active':''}" onclick="switchPage(${i})">
      <span class="page-icon">📄</span>
      <span>${p.name}</span>
      ${pages.length>1?`<span class="page-del" onclick="deletePage(${i},event)">🗑</span>`:''}
    </div>
  `).join('');
}

function renderCanvas(){
  const body=document.getElementById('canvasBody');
  const page=pages[currentPageIdx];
  if(!page||!page.components.length){
    body.innerHTML='<div class="drop-zone-hint"><div style="font-size:2rem;margin-bottom:8px">🎨</div><div>Glisse des composants ici</div><div style="font-size:.72rem;margin-top:4px;color:#9ca3af">ou clique sur un composant à gauche</div></div>';
    body.classList.add('empty');
    return;
  }
  body.classList.remove('empty');
  body.innerHTML=page.components.map((c,i)=>renderComp(c,i)).join('');
  // Re-bind selected
  if(selectedCompId){
    const el=document.getElementById(selectedCompId);
    if(el) el.classList.add('selected');
  }
}

function renderComp(c,idx){
  const html=buildCompHTML(c);
  return `<div class="r-comp" id="${c.id}" onclick="selectComp('${c.id}',event)" data-idx="${idx}">
    <div class="r-comp-actions">
      ${idx>0?`<button class="r-ca-btn r-ca-up" onclick="moveComp('${c.id}',-1,event)">↑</button>`:''}
      ${idx<pages[currentPageIdx].components.length-1?`<button class="r-ca-btn r-ca-down" onclick="moveComp('${c.id}',1,event)">↓</button>`:''}
      <button class="r-ca-btn r-ca-dup" onclick="dupComp('${c.id}',event)">⧉</button>
      <button class="r-ca-btn r-ca-del" onclick="delComp('${c.id}',event)">✕</button>
    </div>
    ${html}
  </div>`;
}

function buildCompHTML(c){
  const p=c.props||{};
  const primary=appData.color||'#16a34a';
  switch(c.type){
    case 'header': return `<div class="rc-header" style="background:${p.bgColor||primary}"><h1>${p.title||'Titre'}</h1>${p.subtitle?`<p>${p.subtitle}</p>`:''}</div>`;
    case 'hero': return `<div class="rc-hero">${p.imageUrl?`<img src="${p.imageUrl}" style="width:80px;height:80px;border-radius:16px;margin-bottom:12px;object-fit:cover" onerror="this.style.display='none'">`:'<div style="font-size:3rem;margin-bottom:10px">🌟</div>'}<h2>${p.title||'Titre'}</h2><p>${p.subtitle||'Description'}</p></div>`;
    case 'text': return `<div class="rc-text" style="text-align:${p.align||'left'}">${p.heading?`<h3>${p.heading}</h3>`:''}<p>${p.content||'Texte...'}</p></div>`;
    case 'image': return `<div class="rc-image" style="aspect-ratio:${p.aspectRatio||'16/9'}">${p.src?`<img src="${p.src}" onerror="this.style.display='none'">`:'📷 Image'}</div>`;
    case 'video': return `<div class="rc-video"><div class="play">▶</div><div class="vt">${p.title||'Vidéo'}</div></div>`;
    case 'audio': return `<div class="rc-audio"><div class="a-icon">🎵</div><div class="a-info"><div class="a-title">${p.title||'Piste audio'}</div><div class="a-time">${p.artist||''} · ${p.duration||'0:00'}</div><div class="a-bar"><div class="a-fill"></div></div></div><span style="font-size:1.4rem;cursor:pointer">▶</span></div>`;
    case 'btn-primary': return `<button class="rc-btn rc-btn-primary" style="background:${primary}" onclick="handleBtnAction('${p.action||''}','${p.actionValue||''}',event)">${p.text||'Bouton'}</button>`;
    case 'btn-secondary': return `<button class="rc-btn rc-btn-secondary" onclick="handleBtnAction('${p.action||''}','${p.actionValue||''}',event)">${p.text||'Bouton'}</button>`;
    case 'btn-outline': return `<button class="rc-btn rc-btn-outline" style="border-color:${primary};color:${primary}" onclick="handleBtnAction('${p.action||''}','${p.actionValue||''}',event)">${p.text||'Bouton'}</button>`;
    case 'btn-danger': return `<button class="rc-btn rc-btn-danger" onclick="handleBtnAction('${p.action||''}','${p.actionValue||''}',event)">${p.text||'Bouton'}</button>`;
    case 'input': return `<div class="rc-input-wrap"><label>${p.label||'Champ'}</label><input class="rc-input" type="${p.type||'text'}" placeholder="${p.placeholder||''}"></div>`;
    case 'password': return `<div class="rc-input-wrap"><label>${p.label||'Mot de passe'}</label><input class="rc-input" type="password" placeholder="${p.placeholder||'••••••••'}"></div>`;
    case 'select': return `<div class="rc-input-wrap"><label>${p.label||'Sélectionner'}</label><select class="rc-select">${(p.options||'Option 1\nOption 2').split('\n').map(o=>`<option>${o}</option>`).join('')}</select></div>`;
    case 'checkbox': return `<div class="rc-checkbox-wrap"><input type="checkbox" ${p.checked?'checked':''}><label>${p.label||'Case à cocher'}</label></div>`;
    case 'switch': return `<div class="rc-switch-wrap"><div class="rc-switch-label">${p.label||'Switch'}</div><div class="rc-sw ${p.on?'on':''}" onclick="this.classList.toggle('on')"></div></div>`;
    case 'formwrap': return `<div class="rc-form-wrap"><div class="rc-form-title" style="color:${primary}">${p.title||'Formulaire'}</div><div class="rc-input-wrap"><label>Nom</label><input class="rc-input" placeholder="Votre nom"></div><div class="rc-input-wrap"><label>Message</label><input class="rc-input" placeholder="Votre message..."></div><button class="rc-btn rc-btn-primary" style="background:${primary};margin:8px 0 0">${p.submitText||'Envoyer'}</button></div>`;
