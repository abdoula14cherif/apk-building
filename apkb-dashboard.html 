    case 'sharebar': return `<div class="rc-share-bar">${(p.platforms||'WhatsApp\nTelegram\nFacebook\nCopier').split('\n').map((pl,i)=>{const icons=['📱','✈️','👍','📋'];const colors=['#25d366','#0088cc','#1877f2','#6b7280'];return`<div class="rc-share-item"><div class="rc-share-icon" style="background:${colors[i%colors.length]}22">${icons[i%icons.length]}</div><div class="rc-share-label">${pl}</div></div>`}).join('')}</div>`;
    case 'notif': return `<div class="rc-notif"><div class="ni">🔔</div><div><div class="nt">${p.title||'Notification'}</div><div class="ns">${p.message||'Message de notification'}</div></div></div>`;
    case 'statrow': return `<div class="rc-stat-row">${(p.stats||'100|Stat').split('\n').map(s=>{const[v,l]=s.split('|');return`<div class="rc-stat"><div class="sv" style="color:${primary}">${v}</div><div class="sl">${l||''}</div></div>`}).join('')}</div>`;
    case 'coursecard': return `<div class="rc-course-card"><div class="rc-course-img">${p.emoji||'📚'}</div><div class="rc-course-body"><div class="rc-course-title">${p.title||'Titre du cours'}</div><div class="rc-course-meta"><span>👨‍🏫 ${p.instructor||'Instructeur'}</span><span>⏱ ${p.duration||'2h'}</span></div><div class="rc-course-prog"><div class="rc-course-prog-fill" style="width:${p.progress||0}%;background:${primary}"></div></div></div></div>`;
    case 'musicplayer': return `<div class="rc-music-player"><div class="rc-mp-cover">${p.emoji||'🎵'}</div><div class="rc-mp-title">${p.title||'Chanson'}</div><div class="rc-mp-artist">${p.artist||'Artiste'}</div><div class="rc-mp-controls"><button class="rc-mp-btn">⏮</button><button class="rc-mp-btn play" style="background:${primary}">▶</button><button class="rc-mp-btn">⏭</button></div></div>`;
    case 'chatbubble': return `<div class="rc-chat-bubble"><div class="cb-msg recv">${p.message||'Message'}</div><div class="rc-cb-time">${p.time||''}</div></div>`;
    case 'chatbubble-sent': return `<div class="rc-chat-bubble sent"><div class="cb-msg sent" style="background:${primary}">${p.message||'Message'}</div><div class="rc-cb-time">${p.time||''}</div></div>`;
    default: return `<div style="padding:10px 16px;font-size:.8rem;color:var(--mu)">Composant: ${c.type}</div>`;
  }
}

// ════════════════════════════════════════════
// COMPONENT ACTIONS
// ════════════════════════════════════════════
function selectComp(id,e){
  if(e) e.stopPropagation();
  selectedCompId=id;
  document.querySelectorAll('.r-comp').forEach(el=>el.classList.remove('selected'));
  const el=document.getElementById(id);
  if(el) el.classList.add('selected');
  showProps(id);
}

function delComp(id,e){
  if(e){e.stopPropagation();}
  const page=pages[currentPageIdx];
  page.components=page.components.filter(c=>c.id!==id);
  if(selectedCompId===id){selectedCompId=null;hideProps();}
  renderCanvas();
  autoSave();
}

function dupComp(id,e){
  if(e){e.stopPropagation();}
  const page=pages[currentPageIdx];
  const idx=page.components.findIndex(c=>c.id===id);
  if(idx<0) return;
  const orig=page.components[idx];
  const copy={...orig,id:uid(),props:{...orig.props}};
  page.components.splice(idx+1,0,copy);
  renderCanvas();
  autoSave();
  toast('Composant dupliqué','ok');
}

function moveComp(id,dir,e){
  if(e){e.stopPropagation();}
  const page=pages[currentPageIdx];
  const idx=page.components.findIndex(c=>c.id===id);
  const newIdx=idx+dir;
  if(newIdx<0||newIdx>=page.components.length) return;
  const tmp=page.components[idx];
  page.components[idx]=page.components[newIdx];
  page.components[newIdx]=tmp;
  renderCanvas();
  autoSave();
}

function handleBtnAction(action,value,e){
  if(e) e.stopPropagation();
  if(action==='alert') alert(value||'Action déclenchée !');
  else if(action==='navigate'){const pi=pages.findIndex(p=>p.name===value);if(pi>=0)switchPage(pi);}
  else if(action==='share') navigator.share?navigator.share({title:appData.name,url:window.location.href}):toast('Partage non supporté');
  else if(action==='openUrl'&&value) window.open(value,'_blank');
}

