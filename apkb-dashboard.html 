    <span style="cursor:pointer;color:var(--red);margin-left:6px" onclick="removeLogic('${comp.id}',${i})">✕</span></div>`).join('')}
    </div>
    <div class="logic-add" onclick="openLogicModal('${comp.id}')">+ Ajouter une action</div>
  </div>
  <div class="prop-group">
    <div class="prop-group-title">Naviguer vers (page)</div>
    <select class="prop-input prop-select" onchange="updateProp('${comp.id}','actionValue',this.value);updateProp('${comp.id}','action','navigate')">
      <option value="">Sélectionner une page...</option>
      ${pages.map(p=>`<option value="${p.name}" ${comp.props&&comp.props.actionValue===p.name?'selected':''}>${p.name}</option>`).join('')}
