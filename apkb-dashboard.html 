async function init(){
  const {data:{session}}=await sb.auth.getSession();
  if(!session){window.location.href='apk-building.html';return;}
  currentUser=session.user;
  appId=urlParams.get('app');
  if(appId){await loadApp();}
  else{initDefaultApp();}
  document.getElementById('loadingOverlay').style.display='none';
  document.getElementById('mainShell').style.display='grid';
  setupDragDrop();
}

function initDefaultApp(){
  appData={name:'Mon App',color:'#16a34a',type:'general'};
  pages=[{id:uid(),name:'Accueil',components:[]}];
  currentPageIdx=0;
  renderAll();
}

async function loadApp(){
  const{data:app}=await sb.from('apps').select('*').eq('id',appId).single();
  if(!app){initDefaultApp();return;}
  appData={name:app.name||'Mon App',color:app.palette||'#16a34a',type:app.type||'general'};
  try{pages=JSON.parse(app.builder_data||'null')||[{id:uid(),name:'Accueil',components:[]}];}
  catch{pages=[{id:uid(),name:'Accueil',components:[]}];}
  document.getElementById('appNameInput').value=appData.name;
  setCanvasColor(appData.color);
  renderAll();
}

async function autoSave(){
  clearTimeout(saveTimer);
  saveTimer=setTimeout(async()=>{
    appData.name=document.getElementById('appNameInput').value||'Mon App';
    if(appId){
      await sb.from('apps').update({
        name:appData.name,
        builder_data:JSON.stringify(pages),
        palette:appData.color,
        updated_at:new Date().toISOString()
      }).eq('id',appId);
    }
    toast('✓ Sauvegardé','ok');
  },1200);
}

