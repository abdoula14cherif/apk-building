    case 'rating': return '<div style="padding:8px 16px;display:flex;gap:4px">'+'⭐'.repeat(p.value||4)+'☆'.repeat(5-(p.value||4))+'<span style="font-size:.75rem;color:#6b7280;margin-left:8px;font-weight:700">'+(p.label||'')+'</span></div>';
    case 'map': return '<div style="width:calc(100% - 32px);margin:10px 16px;border-radius:12px;background:#e2e8f0;height:160px;display:flex;align-items:center;justify-content:center;color:#6b7280;flex-direction:column;gap:6px"><span style="font-size:2rem">🗺️</span><span style="font-size:.85rem;font-weight:700">'+(p.address||'Localisation')+'</span></div>';
    case 'countdown': return '<div style="text-align:center;padding:20px 16px;background:#f0fdf4"><div style="font-size:.72rem;font-weight:700;color:#6b7280;margin-bottom:6px">'+(p.label||'Expire dans')+'</div><div id="countdown_'+c.id+'" style="font-size:2.5rem;font-weight:900;color:'+primary+';font-family:monospace">'+String(p.hours||0).padStart(2,'0')+':'+String(p.minutes||30).padStart(2,'0')+':00</div></div>';
    case 'pricingcard': return '<div style="margin:10px 16px;background:linear-gradient(135deg,'+primary+','+primary+'cc);color:#fff;border-radius:16px;padding:20px;text-align:center"><div style="font-size:.85rem;font-weight:700;opacity:.85;margin-bottom:4px">'+(p.name||'Plan')+'</div><div style="font-size:2rem;font-weight:900;margin-bottom:8px">'+(p.price||'9,99€')+'</div>'+(p.features||'').split("\n").map(function(f){return'<div style="font-size:.75rem;opacity:.85;margin-bottom:4px">'+f+'</div>'}).join('')+'</div>';
    case 'sociallogin': return '<div style="padding:12px 16px;display:flex;gap:10px">'+(p.google!==false?'<button onclick="alert('Connexion Google')" style="flex:1;padding:10px;border-radius:10px;border:1.5px solid #e5e7eb;background:#fff;font-family:Nunito,sans-serif;font-size:.78rem;font-weight:800;cursor:pointer">🌐 Google</button>':'')+(p.facebook!==false?'<button onclick="alert('Connexion Facebook')" style="flex:1;padding:10px;border-radius:10px;border:none;background:#1877f2;color:#fff;font-family:Nunito,sans-serif;font-size:.78rem;font-weight:800;cursor:pointer">Facebook</button>':'')+'</div>';
    case 'sharebar': return '<div style="display:flex;gap:8px;padding:10px 16px;overflow-x:auto">'+(p.platforms||'WhatsApp\nTelegram\nFacebook\nCopier').split("\n").map(function(pl,i){var icons=["📱","✈️","👍","📋"];return'<div onclick="shareApp(''+pl+'')" style="display:flex;flex-direction:column;align-items:center;gap:4px;flex-shrink:0;cursor:pointer"><div style="width:44px;height:44px;border-radius:12px;background:#f3f4f6;display:flex;align-items:center;justify-content:center;font-size:1.2rem">'+icons[i%4]+'</div><div style="font-size:.62rem;font-weight:700;color:#6b7280">'+pl+'</div></div>'}).join('')+'</div>';
    case 'notif': return '<div style="margin:8px 16px;display:flex;align-items:flex-start;gap:12px;padding:12px 14px;background:#fff;border-left:3px solid '+primary+';border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,.06)"><div style="font-size:1.1rem;margin-top:2px">🔔</div><div><div style="font-size:.82rem;font-weight:700;margin-bottom:2px">'+(p.title||'Notif')+'</div><div style="font-size:.72rem;color:#6b7280">'+(p.message||'Message')+'</div></div></div>';
    case 'statrow': return '<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;padding:12px 16px">'+(p.stats||'100|Stat').split("\n").map(function(s){var parts=s.split("|");return'<div style="background:#f0fdf4;border:1px solid #dcfce7;border-radius:10px;padding:14px;text-align:center"><div style="font-size:1.4rem;font-weight:900;color:'+primary+'">'+parts[0]+'</div><div style="font-size:.65rem;font-weight:700;color:#6b7280;text-transform:uppercase">'+(parts[1]||'')+'</div></div>'}).join('')+'</div>';
    case 'coursecard': return '<div style="margin:10px 16px;background:#fff;border:1.5px solid #e5e7eb;border-radius:12px;overflow:hidden"><div style="height:100px;background:linear-gradient(135deg,'+primary+','+primary+'cc);display:flex;align-items:center;justify-content:center;font-size:2.5rem">'+(p.emoji||'📚')+'</div><div style="padding:12px"><div style="font-size:.88rem;font-weight:800;margin-bottom:4px">'+(p.title||'Cours')+'</div><div style="font-size:.72rem;color:#6b7280;font-weight:600;display:flex;gap:10px;margin-bottom:8px"><span>👨‍🏫 '+(p.instructor||'Prof')+'</span><span>⏱ '+(p.duration||'2h')+'</span></div><div style="height:5px;background:#e5e7eb;border-radius:100px;overflow:hidden"><div style="width:'+(p.progress||0)+'%;height:100%;background:'+primary+';border-radius:100px"></div></div></div></div>';
    case 'musicplayer': return '<div style="margin:10px 16px;background:linear-gradient(135deg,#1f2937,#374151);border-radius:16px;padding:20px;color:#fff;text-align:center"><div style="width:80px;height:80px;border-radius:12px;background:'+primary+';margin:0 auto 12px;display:flex;align-items:center;justify-content:center;font-size:2.5rem">'+(p.emoji||'🎵')+'</div><div style="font-size:.92rem;font-weight:800;margin-bottom:2px">'+(p.title||'Chanson')+'</div><div style="font-size:.75rem;opacity:.7;margin-bottom:14px">'+(p.artist||'Artiste')+'</div><div style="display:flex;align-items:center;justify-content:center;gap:16px"><button onclick="alert('Précédent')" style="background:rgba(255,255,255,.15);border:none;color:#fff;width:38px;height:38px;border-radius:50%;font-size:1rem;cursor:pointer">⏮</button><button onclick="this.textContent=this.textContent==='▶'?'⏸':'▶'" style="background:'+primary+';border:none;color:#fff;width:50px;height:50px;border-radius:50%;font-size:1.3rem;cursor:pointer">▶</button><button onclick="alert('Suivant')" style="background:rgba(255,255,255,.15);border:none;color:#fff;width:38px;height:38px;border-radius:50%;font-size:1rem;cursor:pointer">⏭</button></div></div>';
    case 'chatbubble': return '<div style="padding:6px 16px;display:flex;gap:8px;align-items:flex-end"><div style="padding:10px 14px;border-radius:16px;max-width:75%;font-size:.82rem;line-height:1.4;background:#f3f4f6;color:#111">'+(p.message||'Message')+'</div><div style="font-size:.62rem;color:#6b7280">'+(p.time||'')+'</div></div>';
    case 'chatbubble-sent': return '<div style="padding:6px 16px;display:flex;flex-direction:row-reverse;gap:8px;align-items:flex-end"><div style="padding:10px 14px;border-radius:16px;max-width:75%;font-size:.82rem;line-height:1.4;background:'+primary+';color:#fff;border-radius:16px 16px 4px 16px">'+(p.message||'Message')+'</div><div style="font-size:.62rem;color:#6b7280">'+(p.time||'')+'</div></div>';
    default: return '<div style="padding:10px 16px;font-size:.8rem;color:#6b7280">'+c.type+'</div>';
  }
}

function renderPage(idx){
  var page=PAGES[idx];
  if(!page) return;
  document.getElementById('appRoot').innerHTML='<div class="app-page active" id="pg">'+page.components.map(function(c){return buildHTML(c)}).join('')+'</div>';
  // Re-attach switch styles
  document.querySelectorAll('.rc-sw').forEach(function(sw){
    sw.style.cssText='width:44px;height:24px;background:'+(sw.classList.contains('on')?primaryColor:'#d1d5db')+';border-radius:100px;position:relative;cursor:pointer;transition:background .2s';
    sw.addEventListener('click',function(){this.classList.toggle('on');this.style.background=this.classList.contains('on')?primaryColor:'#d1d5db';});
  });
  // Countdown
  page.components.forEach(function(c){
    if(c.type==='countdown'){
      var el=document.getElementById('countdown_'+c.id);
      if(!el) return;
      var s=(c.props.hours||0)*3600+(c.props.minutes||30)*60+(c.props.seconds||0);
      var iv=setInterval(function(){
        s--; if(s<0){clearInterval(iv);return;}
        var h=Math.floor(s/3600),m=Math.floor((s%3600)/60),sec=s%60;
        if(el) el.textContent=String(h).padStart(2,'0')+':'+String(m).padStart(2,'0')+':'+String(sec).padStart(2,'0');
      },1000);
    }
  });
}

function navigateTo(name){
  var idx=PAGES.findIndex(function(p){return p.name===name});
  if(idx>=0){currentPageIdx=idx;renderPage(idx);}
}

function shareApp(platform){
  if(navigator.share&&(platform==='WhatsApp'||platform==='Copier')){
    navigator.share({title:'${name}',url:window.location.href}).catch(function(){});
  } else {
    navigator.clipboard?navigator.clipboard.writeText(window.location.href):alert('Lien copié: '+window.location.href);
    alert(platform+' — Lien copié !');
  }
}

document.addEventListener('click',function(e){
  var btn=e.target.closest('[data-action]');
  if(!btn) return;
  var action=btn.dataset.action, val=btn.dataset.value;
  if(action==='navigate') navigateTo(val);
  else if(action==='alert') alert(val||'Action !');
  else if(action==='share') shareApp('Partage');
  else if(action==='openUrl'&&val) window.open(val,'_blank');
  else if(action==='submit'){
    var form=btn.closest('form,.rc-form-wrap');
    alert('Formulaire envoyé ! Merci.');
  }
});

renderPage(0);
<\/script>
</body>
