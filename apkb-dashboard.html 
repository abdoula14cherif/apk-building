  else{canvasZoom=Math.min(1.5,Math.max(0.5,canvasZoom+dir*0.1));}
  document.getElementById('canvasPhone').style.transform=`scale(${canvasZoom})`;
  document.getElementById('canvasPhone').style.transformOrigin='top center';
}

