function logicIcon(type){return{navigate:'🔗',alert:'💬',submit:'📤',toggle:'🔄',share:'📢',openUrl:'🌐'}[type]||'⚡';}
function logicLabel(type){return{navigate:'Naviguer',alert:'Afficher message',submit:'Soumettre formulaire',toggle:'Toggle élément',share:'Partager',openUrl:'Ouvrir URL'}[type]||type;}

let logicTargetId=null;
function openLogicModal(compId){logicTargetId=compId;openModal('logicModal');}
function addLogic(type){
  if(!logicTargetId) return;
  const page=pages[currentPageIdx];
  const comp=page.components.find(c=>c.id===logicTargetId);
  if(!comp) return;
  if(!comp.logics) comp.logics=[];
  comp.logics.push({type,value:''});
  closeModal('logicModal');
  showProps(logicTargetId);
  autoSave();
  toast('Action ajoutée','ok');
}
function removeLogic(compId,idx){
  const comp=pages[currentPageIdx].components.find(c=>c.id===compId);
  if(comp&&comp.logics) comp.logics.splice(idx,1);
  showProps(compId);
  autoSave();
}

function updateProp(compId,key,val){
  const page=pages[currentPageIdx];
  const comp=page.components.find(c=>c.id===compId);
  if(!comp) return;
  if(!comp.props) comp.props={};
  comp.props[key]=val;
  // Apply inline style if style prop
  const el=document.getElementById(compId);
  if(el&&key==='bgColor') el.style.backgroundColor=val;
  renderCanvas();
  if(selectedCompId===compId) selectComp(compId,null);
  autoSave();
}

function switchRpTab(tab,el){
  rpTab=tab;
  document.querySelectorAll('.rp-tab').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
  if(selectedCompId){
    const comp=pages[currentPageIdx].components.find(c=>c.id===selectedCompId);
    if(comp) renderPropsBody(comp);
  }
}

