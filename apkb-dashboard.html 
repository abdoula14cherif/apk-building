// DRAG AND DROP
// ════════════════════════════════════════════
function setupDragDrop(){
  document.querySelectorAll('[draggable=true]').forEach(el=>{
    el.addEventListener('dragstart',e=>{
      dragComp=el.dataset.comp;
      e.dataTransfer.effectAllowed='copy';
    });
    el.addEventListener('click',()=>addCompToCanvas(el.dataset.comp));
  });
}

function onDragOver(e){
  e.preventDefault();
  e.dataTransfer.dropEffect='copy';
  document.getElementById('canvasBody').classList.add('drag-over');
}
function onDragLeave(){document.getElementById('canvasBody').classList.remove('drag-over');}
function onDrop(e){
  e.preventDefault();
  document.getElementById('canvasBody').classList.remove('drag-over');
  if(dragComp) addCompToCanvas(dragComp);
  dragComp=null;
}

function addCompToCanvas(type){
  const def=COMP_DEFS[type];
  if(!def) return;
  const comp={id:uid(),type,props:{...(def.defaults||{})},logics:[]};
  pages[currentPageIdx].components.push(comp);
  renderCanvas();
  selectComp(comp.id,null);
  autoSave();
  document.getElementById('canvasPhone').scrollTop=9999;
}

