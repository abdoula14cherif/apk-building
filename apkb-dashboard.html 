function showProps(id){
  const page=pages[currentPageIdx];
  const comp=page.components.find(c=>c.id===id);
  if(!comp) return;
  const def=COMP_DEFS[comp.type]||{label:comp.type,icon:'⚙️'};
  document.getElementById('rpNoSel').style.display='none';
  document.getElementById('rpProps').style.display='block';
  document.getElementById('rpTitle').textContent=`${def.icon||'⚙️'} ${def.label||comp.type}`;
  renderPropsBody(comp);
}

function hideProps(){
  document.getElementById('rpNoSel').style.display='block';
  document.getElementById('rpProps').style.display='none';
}

function renderPropsBody(comp){
  const p=comp.props||{};
  let html='';
  if(rpTab==='props'){
    html=buildPropsFields(comp);
  } else if(rpTab==='style'){
    html=buildStyleFields(comp);
  } else if(rpTab==='logic'){
    html=buildLogicFields(comp);
  }
  document.getElementById('rpBody').innerHTML=html;
}

