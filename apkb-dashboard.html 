function downloadApp(){
  const appName=(appData.name||'monapp').toLowerCase().replace(/\s+/g,'-');
  const html=generateFullAPK();
  const blob=new Blob([html],{type:'text/html;charset=utf-8'});
  const url=URL.createObjectURL(blob);
  const a=document.createElement('a');
  a.href=url; a.download=appName+'.html'; a.click();
  URL.revokeObjectURL(url);
  toast('📥 App téléchargée ! Ouvre avec Chrome Android.','ok');
  if(appId&&currentUser){
    sb.from('build_history').insert({app_id:appId,user_id:currentUser.id,status:'success',file_size_kb:Math.round(blob.size/1024)});
    sb.from('apps').update({status:'ready',download_count:1,updated_at:new Date().toISOString()}).eq('id',appId);
  }
}

