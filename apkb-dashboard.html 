// PAGES
// ════════════════════════════════════════════
function switchPage(idx){
  currentPageIdx=idx;
  selectedCompId=null;
  hideProps();
  renderAll();
}

function openPageModal(){openModal('pageModal');}
function selTemplate(el,t){
  selectedTemplate=t;
  document.querySelectorAll('#pageTemplates .comp-item').forEach(i=>i.style.outline='none');
  el.style.outline='2px solid var(--g)';
}

function addPage(){
  const name=document.getElementById('newPageName').value.trim()||`Page ${pages.length+1}`;
  const template=TEMPLATES[selectedTemplate]||[];
  const comps=template.map(c=>({id:uid(),type:c.type,props:{...c.props},logics:[]}));
  pages.push({id:uid(),name,components:comps});
  currentPageIdx=pages.length-1;
  closeModal('pageModal');
  document.getElementById('newPageName').value='';
  selectedTemplate='blank';
  document.querySelectorAll('#pageTemplates .comp-item').forEach(i=>i.style.outline='none');
  renderAll();
  autoSave();
  toast(`Page "${name}" créée`,'ok');
}

function deletePage(idx,e){
  if(e) e.stopPropagation();
  if(pages.length<=1){toast('Impossible de supprimer la seule page','err');return;}
  if(!confirm(`Supprimer la page "${pages[idx].name}" ?`)) return;
  pages.splice(idx,1);
  if(currentPageIdx>=pages.length) currentPageIdx=pages.length-1;
  renderAll();
  autoSave();
}

